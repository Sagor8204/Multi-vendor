# Django Settings
# Generate a new secret key for production: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
# Options: 'sqlite' or 'postgresql'
DATABASE_TYPE=postgresql

# SQLite Database (used when DATABASE_TYPE=sqlite)
DATABASE_NAME=db.sqlite3

# PostgreSQL Database (used when DATABASE_TYPE=postgresql)
POSTGRES_DB=db-name
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Security
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_SECURE=True

# CSRF Trusted Origins - required for Docker/production deployments behind a reverse proxy
# Must include the full scheme (https://) and domain for all origins that send POST requests
CSRF_TRUSTED_ORIGINS=https://sites.com

# Timezone
TIME_ZONE=UTC
USE_I18N=True
USE_TZ=True

# Static files
STATIC_URL=static/
